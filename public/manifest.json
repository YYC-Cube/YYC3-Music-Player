{
  "name": "D-Music Player",
  "short_name": "D-Music",
  "description": "D-Music 智能音乐平台 — 董小姐原创音乐生态系统",
  "start_url": "/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#06050e",
  "theme_color": "#7c3aed",
  "categories": ["music", "entertainment"],
  "prefer_related_applications": false,
  "scope": "/",
  "lang": "zh-CN",
  "dir": "ltr",
  "icons": [
    {
      "src": "/D-brand/android/mipmap-mdpi/ic_launcher.png",
      "sizes": "48x48",
      "type": "image/png"
    },
    {
      "src": "/D-brand/android/mipmap-hdpi/ic_launcher.png",
      "sizes": "72x72",
      "type": "image/png"
    },
    {
      "src": "/D-brand/android/mipmap-xhdpi/ic_launcher.png",
      "sizes": "96x96",
      "type": "image/png"
    },
    {
      "src": "/D-brand/android/mipmap-xxhdpi/ic_launcher.png",
      "sizes": "144x144",
      "type": "image/png"
    },
    {
      "src": "/D-brand/android/mipmap-xxxhdpi/ic_launcher.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/D-brand/ios/AppIcon.appiconset/Icon-App-1024x1024@1x.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/D-brand/ios/AppIcon.appiconset/Icon-App-1024x1024@1x.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "搜索音乐",
      "short_name": "搜索",
      "url": "/?action=search",
      "icons": [
        {
          "src": "/D-brand/android/mipmap-xhdpi/ic_launcher.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "沉浸模式",
      "short_name": "沉浸",
      "url": "/?mode=immersive",
      "icons": [
        {
          "src": "/D-brand/android/mipmap-xhdpi/ic_launcher.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "share_target": {
    "action": "/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "files": [
        {
          "name": "audio",
          "accept": ["audio/*", "video/mp4"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+dmusic",
      "url": "/?track=%s"
    }
  ],
  "related_applications": [],
  "iarc_rating_id": ""
}
